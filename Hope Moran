<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hope for Rahway | Independent Candidate for Mayor</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #D4A017;
      --dark: #0E0E0E;
      --mid: #1A1A1A;
      --cream: #F5F0E8;
      --muted: #888;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--dark);
      color: var(--cream);
      font-family: 'Source Sans 3', sans-serif;
      font-weight: 300;
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.2rem 2.5rem;
      background: rgba(14,14,14,0.92);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid rgba(212,160,23,0.2);
    }

    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      color: var(--gold);
      text-decoration: none;
      letter-spacing: 0.03em;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      color: var(--cream);
      text-decoration: none;
      font-size: 0.85rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      opacity: 0.7;
      transition: opacity 0.2s;
    }

    .nav-links a:hover { opacity: 1; color: var(--gold); }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 8rem 2.5rem 4rem;
      max-width: 900px;
    }

    .hero-eyebrow {
      font-size: 0.8rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
      opacity: 0.9;
    }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(4rem, 10vw, 8rem);
      line-height: 1;
      font-weight: 900;
      margin-bottom: 1.5rem;
      animation: fadeUp 0.9s ease both;
    }

    .hero h1 span { color: var(--gold); }

    .hero-sub {
      font-size: 1.2rem;
      max-width: 600px;
      opacity: 0.75;
      margin-bottom: 2.5rem;
      animation: fadeUp 0.9s 0.15s ease both;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      animation: fadeUp 0.9s 0.3s ease both;
    }

    /* BUTTONS */
    .btn {
      display: inline-block;
      padding: 0.85rem 2rem;
      font-size: 0.85rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      font-family: 'Source Sans 3', sans-serif;
      font-weight: 600;
      cursor: pointer;
      border: none;
      transition: all 0.2s;
    }

    .btn-primary {
      background: var(--gold);
      color: var(--dark);
    }

    .btn-primary:hover { background: #e6b31e; }

    .btn-outline {
      background: transparent;
      color: var(--cream);
      border: 1px solid rgba(245,240,232,0.3);
    }

    .btn-outline:hover { border-color: var(--gold); color: var(--gold); }

    /* SECTIONS */
    section { padding: 6rem 2.5rem; }

    .container { max-width: 1100px; margin: 0 auto; }

    .section-label {
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 1.5rem;
    }

    /* ABOUT */
    #about { background: var(--mid); }

    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }

    .about-text p { margin-bottom: 1rem; opacity: 0.85; }

    .about-visual {
      background: rgba(212,160,23,0.08);
      border: 1px solid rgba(212,160,23,0.2);
      padding: 2.5rem;
    }

    .about-visual blockquote {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      line-height: 1.5;
      font-style: italic;
      color: var(--gold);
    }

    /* PLATFORM */
    #platform { background: var(--dark); }

    .platform-intro {
      max-width: 650px;
      margin-bottom: 3rem;
      opacity: 0.8;
    }

    .pillars {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .pillar {
      border: 1px solid rgba(245,240,232,0.1);
      padding: 2rem;
      transition: border-color 0.3s;
    }

    .pillar:hover { border-color: var(--gold); }

    .pillar-num {
      font-family: 'Playfair Display', serif;
      font-size: 3rem;
      color: rgba(212,160,23,0.2);
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    .pillar h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      margin-bottom: 0.75rem;
      color: var(--gold);
    }

    .pillar p { font-size: 0.95rem; opacity: 0.75; }

    /* TRANSPARENCY */
    #transparency { background: var(--mid); }

    .transparency-box {
      border-left: 3px solid var(--gold);
      padding: 2rem 2.5rem;
      background: rgba(212,160,23,0.05);
      max-width: 750px;
    }

    .transparency-box p { opacity: 0.85; margin-bottom: 1rem; }
    .transparency-box p:last-child { margin-bottom: 0; }

    /* DONATE */
    #donate { background: var(--dark); }

    .donate-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }

    .donate-text p { opacity: 0.85; margin-bottom: 1rem; }

    .donate-widget {
      background: var(--mid);
      border: 1px solid rgba(212,160,23,0.2);
      padding: 2rem;
    }

    /* CONTACT */
    #contact { background: var(--mid); }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    .contact-item { margin-bottom: 1.5rem; }

    .contact-label {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      opacity: 0.5;
      margin-bottom: 0.3rem;
    }

    .contact-item a {
      color: var(--cream);
      text-decoration: none;
      opacity: 0.85;
    }

    .contact-item a:hover { color: var(--gold); opacity: 1; }

    form { display: flex; flex-direction: column; gap: 1rem; }

    input, textarea {
      background: var(--dark);
      border: 1px solid rgba(245,240,232,0.12);
      color: var(--cream);
      padding: 0.85rem 1rem;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s;
      resize: vertical;
    }

    input:focus, textarea:focus { border-color: var(--gold); }
    input::placeholder, textarea::placeholder { opacity: 0.4; }

    /* FOOTER */
    footer {
      background: #080808;
      padding: 3rem 2.5rem;
      text-align: center;
      border-top: 1px solid rgba(255,255,255,0.05);
    }

    footer p { font-size: 0.82rem; opacity: 0.4; }

    .footer-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      color: var(--gold);
      margin-bottom: 0.75rem;
    }

    /* ANIMATIONS */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { gap: 1rem; }
      .nav-links a { font-size: 0.75rem; }
      section { padding: 4rem 1.5rem; }
      .about-grid, .donate-grid, .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .hero { padding: 7rem 1.5rem 3rem; }
    }
  </style>
</head>
<body>

  <nav>
    <a href="#" class="nav-logo">Hope for Rahway</a>
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#platform">Platform</a></li>
      <li><a href="#donate">Donate</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-eyebrow">Rahway, NJ &mdash; November 2026</div>
    <h1>Hope<br>for <span>Rahway</span></h1>
    <p class="hero-sub">Independent candidate for Mayor. No party bosses. No corporate donors. Just a Rahway resident who's been paying attention — and isn't afraid to say so.</p>
    <div class="hero-cta">
      <a href="#donate" class="btn btn-primary">Support the Campaign</a>
      <a href="#platform" class="btn btn-outline">Read the Platform</a>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <div class="section-label">About Hope</div>
          <h2>Rahway deserves a mayor who works for you.</h2>
          <p>I'm Hope — artist, grandmother, former EMT, community organizer, and independent candidate for Mayor of Rahway.</p>
          <p>I moved to Rahway for the arts district and stayed because this city matters. I've been attending council meetings, asking hard questions about our water, our housing, and who's really making decisions on behalf of residents.</p>
          <p>I'm not backed by a party machine. I'm backed by the people of Rahway — and accountable only to them.</p>
        </div>
        <div class="about-visual">
          <blockquote>"Radical transparency isn't a slogan. It's a promise that city hall will never again make decisions that affect your life without your knowledge."</blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- PLATFORM -->
  <section id="platform">
    <div class="container">
      <div class="section-label">The Five Root Principles</div>
      <h2>A platform built for Rahway residents.</h2>
      <p class="platform-intro">Every issue on this platform came from listening to Rahway residents. These are not talking points — they are commitments.</p>
      <div class="pillars">
        <div class="pillar">
          <div class="pillar-num">01</div>
          <h3>Municipal Water Control</h3>
          <p>Rahway's water belongs to Rahway residents. We will end opaque water contracts and establish full public transparency over our water system, supply, and safety.</p>
        </div>
        <div class="pillar">
          <div class="pillar-num">02</div>
          <h3>Affordable Housing</h3>
          <p>The promises that drew people to Rahway — affordable rents, artist studios, real community — must be honored. We will fight displacement and demand accountability from developers.</p>
        </div>
        <div class="pillar">
          <div class="pillar-num">03</div>
          <h3>Flood Resilience</h3>
          <p>Climate change is not coming — it's here. Rahway must invest in real flood infrastructure and stop greenwashing hardening projects that don't protect residents.</p>
        </div>
        <div class="pillar">
          <div class="pillar-num">04</div>
          <h3>Embedded Mental Health Services</h3>
          <p>Mental health response belongs in our communities, not just our emergency rooms. We will build integrated services that reach residents where they are.</p>
        </div>
        <div class="pillar">
          <div class="pillar-num">05</div>
          <h3>Arts District Development</h3>
          <p>Rahway's creative community is an asset, not an afterthought. We will deliver on the arts district promises and ensure artists can afford to live and work here.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TRANSPARENCY -->
  <section id="transparency">
    <div class="container">
      <div class="section-label">Radical Transparency</div>
      <h2>You have a right to know.</h2>
      <div class="transparency-box">
        <p>City government works best when residents are informed. That means publishing meeting materials in advance, posting contracts publicly, and making OPRA requests unnecessary because the information was never hidden in the first place.</p>
        <p>As Mayor, I will implement open budget dashboards, publish all vendor contracts, and hold regular public office hours — not just election-year town halls.</p>
        <p>Radical transparency is not a risk. It's how trust gets built.</p>
      </div>
    </div>
  </section>

  <!-- DONATE -->
  <section id="donate">
    <div class="container">
      <div class="donate-grid">
        <div class="donate-text">
          <div class="section-label">Support the Campaign</div>
          <h2>This campaign runs on people, not party money.</h2>
          <p>Every dollar donated goes directly toward reaching Rahway voters — door knocking, flyers, events, and getting our message out without a machine behind us.</p>
          <p>No PACs. No bundlers. No strings. Just neighbors investing in their city.</p>
          <p style="font-size:0.8rem; opacity:0.5; margin-top:1.5rem;">Paid for by Hope for Rahway Campaign Committee. Contributions are not tax deductible.</p>
        </div>
        <div class="donate-widget">
          <script type="module" src="https://donorbox.org/widgets.js" async></script>
          <dbox-widget campaign="hope-for-rahway" type="donation_form" enable-auto-scroll="true"></dbox-widget>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact">
    <div class="container">
      <div class="section-label">Get Involved</div>
      <h2>Ready to help? Let's talk.</h2>
      <div class="contact-grid">
        <div>
          <p style="opacity:0.75; margin-bottom:2rem;">Whether you want to volunteer, share a concern, or just introduce yourself — Hope reads everything.</p>
          <div class="contact-item">
            <div class="contact-label">Email</div>
            <a href="mailto:hope@hopeforrahway.com">hope@hopeforrahway.com</a>
          </div>
          <div class="contact-item">
            <div class="contact-label">Facebook</div>
            <a href="https://facebook.com/hopeforrahway" target="_blank">Hope for Rahway</a>
          </div>
          <div class="contact-item">
            <div class="contact-label">TikTok</div>
            <a href="https://tiktok.com/@hopeforrahway" target="_blank">@hopeforrahway</a>
          </div>
          <div class="contact-item">
            <div class="contact-label">Paid for by</div>
            <p style="opacity:0.6; font-size:0.9rem;">Hope for Rahway Campaign Committee<br>Rahway, NJ</p>
          </div>
        </div>
        <div>
          <form onsubmit="handleSubmit(event)">
            <input type="text" placeholder="Your name" required />
            <input type="email" placeholder="Email address" required />
            <textarea rows="4" placeholder="Your message or how you'd like to help..."></textarea>
            <button type="submit" class="btn btn-primary" style="align-self: flex-start;">Send Message</button>
          </form>
          <p id="form-msg" style="margin-top:1rem; color: var(--gold); font-size:0.9rem; display:none;">Thanks! Hope will be in touch.</p>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="footer-logo">Hope for Rahway</div>
    <p>Independent Candidate for Mayor &bull; Rahway, NJ &bull; November 2026</p>
    <p style="margin-top:0.5rem;">Paid for by Hope for Rahway Campaign Committee. Not authorized by any candidate committee.</p>
  </footer>

  <script>
    function handleSubmit(e) {
      e.preventDefault();
      document.getElementById('form-msg').style.display = 'block';
      e.target.reset();
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(el => {
        if (el.isIntersecting) {
          el.target.style.opacity = '1';
          el.target.style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.pillar, .about-visual, .transparency-box').forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      observer.observe(el);
    });
  </script>

</body>
</html>
